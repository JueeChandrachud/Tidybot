    <collision>
      <origin rpy="0 0 0" xyz="0 0 -0.04"/>
      <geometry>
        <cylinder length="0.08" radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 -0.04"/>
      <mass value="0.05026548245743669"/>
      <inertia ixx="3.1834805556376576e-05" ixy="0" ixz="0" iyy="3.1834805556376576e-05" iyz="0" izz="1.005309649148734e-05"/>
    </inertial>
  </link>
  <!-- ====== GRIPPER BASE (fixed to wrist) ====== -->
  <joint name="left_gripper_fix" type="fixed">
    <parent link="left_wrist_link"/>
    <child link="left_gripper_base_link"/>
    <origin rpy="0 0 0" xyz="0 0 -0.095"/>
  </joint>
  <link name="left_gripper_base_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.08 0.1 0.03"/>
      </geometry>
      <material name="gripper_orange"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.08 0.1 0.03"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.12"/>
      <inertia ixx="0.00010900000000000002" ixy="0" ixz="0" iyy="7.3e-05" iyz="0" izz="0.00016400000000000003"/>
    </inertial>
  </link>
  <joint name="left_finger_left_joint" type="fixed">
    <parent link="left_gripper_base_link"/>
    <child link="left_finger_left_link"/>
    <origin rpy="0 0 0" xyz="0 0.02 -0.045"/>
    <axis xyz="0 1 0"/>
  </joint>
  <link name="left_finger_left_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.01 0.015 0.06"/>
      </geometry>
      <material name="gripper_orange"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.01 0.015 0.06"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.006299999999999999"/>
      <inertia ixx="2.008125e-06" ixy="0" ixz="0" iyy="1.9424999999999996e-06" iyz="0" izz="1.7062499999999998e-07"/>
    </inertial>
  </link>
  <joint name="left_finger_right_joint" type="fixed">
    <parent link="left_gripper_base_link"/>
    <child link="left_finger_right_link"/>
    <origin rpy="0 0 0" xyz="0 -0.02 -0.045"/>
    <axis xyz="0 -1 0"/>
  </joint>
  <link name="left_finger_right_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.01 0.015 0.06"/>
      </geometry>
      <material name="gripper_orange"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.01 0.015 0.06"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.006299999999999999"/>
      <inertia ixx="2.008125e-06" ixy="0" ixz="0" iyy="1.9424999999999996e-06" iyz="0" izz="1.7062499999999998e-07"/>
    </inertial>
  </link>
  <!-- ===== Gazebo surface tags =====
         Arm links: mild friction; finger pads: high friction to grip. -->
  <gazebo reference="left_upper_arm_link">
    <material>Gazebo/Grey</material>
  </gazebo>
  <gazebo reference="left_forearm_link">
    <material>Gazebo/Grey</material>
  </gazebo>
  <gazebo reference="left_wrist_link">
    <material>Gazebo/Grey</material>
  </gazebo>
  <gazebo reference="left_gripper_base_link">
    <material>Gazebo/Orange</material>
  </gazebo>
  <gazebo reference="left_finger_left_link">
    <material>Gazebo/Orange</material>
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
    <kp>1e6</kp>
    <kd>100</kd>
    <minDepth>0.0005</minDepth>
  </gazebo>
  <gazebo reference="left_finger_right_link">
    <material>Gazebo/Orange</material>
    <mu1>1.5</mu1>
    <mu2>1.5</mu2>
    <kp>1e6</kp>
    <kd>100</kd>
    <minDepth>0.0005</minDepth>
  </gazebo>
  <material name="lidar_black">
    <color rgba="0.05 0.05 0.05 1.0"/>
  </material>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <!-- Top of chassis (base_link z = +0.06) + half lidar height.
         x=+0.15 puts it in front of torso (torso front face at +0.10). -->
    <origin rpy="0 0 0" xyz="0.15 0 0.08"/>
  </joint>
  <link name="lidar_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.04" radius="0.04"/>
      </geometry>
      <material name="lidar_black"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.04" radius="0.04"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="5.3333333333333326e-05" ixy="0" ixz="0" iyy="5.3333333333333326e-05" iyz="0" izz="8e-05"/>
    </inertial>
  </link>
  <gazebo reference="lidar_link">
    <material>Gazebo/Black</material>
    <sensor name="lidar_sensor" type="ray">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <!-- 200 deg forward wedge (-100 deg to +100 deg). The
                 rear ~160 deg is blocked by the torso/chassis anyway,
                 and self-hits were drawing the robot as a wall in the
                 slam_toolbox map. Keeping 1 deg resolution -> 200
                 samples total. -->
            <samples>200</samples>
            <resolution>1</resolution>
            <min_angle>-1.7453</min_angle>
            <max_angle> 1.7453</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin filename="libgazebo_ros_ray_sensor.so" name="lidar_plugin">
        <ros>
          <remapping>~/out:=scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>
  <link name="imu_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.03 0.03 0.03"/>
      </geometry>
      <material name="face_blue"/>
    </visual>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.02"/>
      <inertia ixx="3e-06" ixy="0" ixz="0" iyy="3e-06" iyz="0" izz="3e-06"/>
    </inertial>
  </link>
  <gazebo reference="imu_link">
    <gravity>true</gravity>
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <visualize>false</visualize>
      <imu>
        <angular_velocity>
          <x>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>2.0e-4</stddev>
            </noise>
          </x>
          <y>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>2.0e-4</stddev>
            </noise>
          </y>
          <z>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>2.0e-4</stddev>
            </noise>
          </z>
        </angular_velocity>
        <linear_acceleration>
          <x>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>1.7e-2</stddev>
            </noise>
          </x>
          <y>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>1.7e-2</stddev>
            </noise>
          </y>
          <z>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>1.7e-2</stddev>
            </noise>
          </z>
        </linear_acceleration>
      </imu>
      <plugin filename="libgazebo_ros_imu_sensor.so" name="imu_plugin">
        <ros>
          <remapping>~/out:=imu</remapping>
        </ros>
        <initial_orientation_as_reference>false</initial_orientation_as_reference>
        <frame_name>imu_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>
  <!-- ~20 deg down -->
  <material name="fcam_green">
    <color rgba="0.10 0.80 0.30 1.0"/>
  </material>
  <joint name="front_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_camera_link"/>
    <!-- front face of chassis: x=+chassis_l/2=+0.225; z=+0.02 above center -->
    <origin rpy="0 0.35 0" xyz="0.225 0 0.02"/>
  </joint>
  <link name="front_camera_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.04 0.06 0.03"/>
      </geometry>
      <material name="fcam_green"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.04 0.06 0.03"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="1.875e-05" ixy="0" ixz="0" iyy="1.0416666666666666e-05" iyz="0" izz="2.1666666666666667e-05"/>
    </inertial>
  </link>
  <!-- Optical frame (z-forward, x-right, y-down) -->
  <joint name="front_camera_optical_joint" type="fixed">
    <parent link="front_camera_link"/>
    <child link="front_camera_optical_frame"/>
    <origin rpy="-1.5707963267948966 0 -1.5707963267948966" xyz="0 0 0"/>
  </joint>
  <link name="front_camera_optical_frame"/>
  <gazebo reference="front_camera_link">
    <material>Gazebo/Green</material>
    <sensor name="front_camera" type="camera">
      <update_rate>15.0</update_rate>
      <visualize>false</visualize>
      <camera name="head">
        <horizontal_fov>1.2</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>6.0</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>
      <plugin filename="libgazebo_ros_camera.so" name="front_camera_plugin">
        <ros>
          <namespace>/front_camera</namespace>
          <remapping>image_raw:=image_raw</remapping>
          <remapping>camera_info:=camera_info</remapping>
        </ros>
        <camera_name>front_camera</camera_name>
        <frame_name>front_camera_optical_frame</frame_name>
      </plugin>
    </sensor>
  </gazebo>
  <material name="tcam_red">
    <color rgba="0.80 0.10 0.10 1.0"/>
  </material>
  <joint name="torso_camera_joint" type="fixed">
    <parent link="torso_link"/>
    <child link="torso_camera_link"/>
    <!-- Upper-middle of torso front face. Torso half-length is 0.10, so
         +0.11 x puts camera just proud of the front. z=+0.15 is about
         two-thirds up the torso. -->
    <origin rpy="0 0 0" xyz="0.11 0 0.15"/>
  </joint>
  <link name="torso_camera_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.04 0.1 0.03"/>
      </geometry>
      <material name="tcam_red"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <box size="0.04 0.1 0.03"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.08"/>
      <inertia ixx="7.266666666666668e-05" ixy="0" ixz="0" iyy="1.6666666666666667e-05" iyz="0" izz="7.733333333333336e-05"/>
    </inertial>
  </link>
  <joint name="torso_camera_optical_joint" type="fixed">
    <parent link="torso_camera_link"/>
    <child link="torso_camera_optical_frame"/>
    <origin rpy="-1.5707963267948966 0 -1.5707963267948966" xyz="0 0 0"/>
  </joint>
  <link name="torso_camera_optical_frame"/>
  <gazebo reference="torso_camera_link">
    <material>Gazebo/Red</material>
    <sensor name="torso_rgbd" type="depth">
      <update_rate>15.0</update_rate>
      <visualize>false</visualize>
      <camera name="rgbd">
        <horizontal_fov>1.2</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>8.0</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>
      <plugin filename="libgazebo_ros_camera.so" name="torso_rgbd_plugin">
        <ros>
          <namespace>/camera</namespace>
        </ros>
        <camera_name>rgbd</camera_name>
        <frame_name>torso_camera_optical_frame</frame_name>
        <min_depth>0.1</min_depth>
        <max_depth>8.0</max_depth>
      </plugin>
    </sensor>
  </gazebo>
  <gazebo>
    <plugin filename="libgazebo_ros_diff_drive.so" name="diff_drive">
      <ros>
        <!-- Default topic names: /cmd_vel, /odom. Namespace left root. -->
      </ros>
      <update_rate>50</update_rate>
      <!-- Two wheel pairs. The plugin treats them as 4 independent
           wheels but slaves front+rear on each side. -->
      <num_wheel_pairs>2</num_wheel_pairs>
      <left_joint>wheel_fl_joint</left_joint>
      <right_joint>wheel_fr_joint</right_joint>
      <left_joint>wheel_rl_joint</left_joint>
      <right_joint>wheel_rr_joint</right_joint>
      <!-- Wheel geometry (mirrors base.xacro). -->
      <wheel_separation>0.40</wheel_separation>
      <wheel_separation>0.40</wheel_separation>
      <wheel_diameter>0.16</wheel_diameter>
      <wheel_diameter>0.16</wheel_diameter>
      <!-- Velocity/acceleration caps. -->
      <max_wheel_torque>20.0</max_wheel_torque>
      <max_wheel_acceleration>2.0</max_wheel_acceleration>
      <!-- Frame IDs match the rest of the tf tree and Nav2 defaults. -->
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
      <publish_odom>true</publish_odom>
      <!-- EKF (robot_localization) owns odom->base_footprint now.
           Two publishers on the same tf = flapping, so plugin stops. -->
      <publish_odom_tf>false</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>
    </plugin>
  </gazebo>
</robot>
